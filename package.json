{
  "name": "@stellar/stellar-base",
  "version": "14.1.0",
  "description": "Low-level support library for the Stellar network.",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.mjs",
  "types": "./lib/types/index.d.ts",
  "packageManager": "pnpm@9.15.3",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.js",
      "default": "./lib/cjs/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:types && rollup -c",
    "build:types": "tsc -p tsconfig.types.json && mkdir -p lib/types/generated && cp src/generated/*.d.ts lib/types/generated/",
    "build:node:prod": "cross-env NODE_ENV=production pnpm run build",
    "build:prod": "cross-env NODE_ENV=production pnpm run build",
    "test": "pnpm run build && pnpm run test:vitest",
    "test:browser": "vitest --run --project browser",
    "test:browser:watch": "vitest --project browser",
    "test:vitest": "vitest --run --project node",
    "test:vitest:ui": "vitest --ui",
    "test:vitest:watch": "vitest --project node",
    "test:vitest:coverage": "vitest --coverage --project node",
    "docs": "jsdoc -c ./.jsdoc.json --verbose",
    "lint": "eslint -c ./eslint.config.cjs src/ && dtslint --localTs node_modules/typescript/lib types/",
    "preversion": "pnpm run clean && pnpm run fmt && pnpm run lint && pnpm run build:prod && pnpm run test",
    "fmt": "prettier --config ./prettier.config.cjs --ignore-path ./.prettierignore --write 'src/**/*.ts'",
    "prepare": "pnpm run build:prod && husky install",
    "clean": "rm -rf lib/ dist/ coverage/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "/dist/*.js",
    "/lib/**/*.js",
    "/lib/types/**/*.d.ts",
    "/.agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stellar/js-stellar-base.git"
  },
  "keywords": [
    "stellar"
  ],
  "author": "Stellar Development Foundation <hello@stellar.org>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/stellar/js-stellar-base/issues"
  },
  "homepage": "https://github.com/stellar/js-stellar-base",
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.0",
    "@definitelytyped/dtslint": "^0.0.182",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.2",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^20.14.11",
    "@types/sha.js": "^2.4.4",
    "@typescript-eslint/parser": "^8.54.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-import-x": "^4.16.1",
    "globals": "^17.3.0",
    "husky": "^8.0.3",
    "jsdoc": "^4.0.5",
    "lint-staged": "^15.5.0",
    "playwright": "^1.53.1",
    "prettier": "^3.8.1",
    "rollup": "^4.44.1",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@noble/curves": "^1.9.6",
    "@stellar/js-xdr": "^3.1.2",
    "base32.js": "^0.1.0",
    "bignumber.js": "^9.3.1",
    "buffer": "^6.0.3",
    "sha.js": "^2.4.12"
  }
}
